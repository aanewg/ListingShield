# ─── ListingShield — Environment variable template ────────────────────────────
# Copy this file to .env and fill in the values.
# .env is gitignored — this file (.env.example) is safe to commit.
#
# SECURITY RULES:
#   • NEVER prefix secrets with NEXT_PUBLIC_ — that ships them to the browser.
#   • NEVER hardcode keys in source files — always use process.env.
#   • Set production values in your hosting dashboard (e.g. Vercel > Settings > Environment Variables).

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Required for AI-powered scam detection.
# Server-side only — used in src/lib/ai-analysis.ts and api/extract-from-screenshot.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Turso (Production SQLite over libSQL) ─────────────────────────────────────
# Optional: leave blank in local dev — the app falls back to a local dev.db file.
# Required in production (Vercel). Create a database at: https://turso.tech/
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Prisma / local SQLite (dev only) ─────────────────────────────────────────
# Used by the Prisma CLI for local migrations. Not needed at runtime.
DATABASE_URL="file:./dev.db"
